{
  "name": "ai-centric-coding-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "DATABASE_URL=file:./test.db pnpm exec prisma migrate deploy && DATABASE_URL=file:./test.db vitest run",
    "db:migrate:sqlite": "DATABASE_URL=file:./prisma/dev.db pnpm exec prisma migrate deploy",
    "db:migrate:postgres": "PRISMA_SCHEMA=prisma/schema.postgres.prisma PRISMA_MIGRATIONS_PATH=prisma/migrations-postgres pnpm exec prisma migrate deploy",
    "db:smoke:postgres": "printf 'SELECT 1;' | PRISMA_SCHEMA=prisma/schema.postgres.prisma PRISMA_MIGRATIONS_PATH=prisma/migrations-postgres pnpm exec prisma db execute --stdin"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "next": "16.1.6",
    "pg": "^8.16.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
